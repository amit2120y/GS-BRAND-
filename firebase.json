{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "**", "destination": "/client/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
      }
    ]
  },
  "firestore": {
    "rules": "server/firestore.rules"
  }
}
