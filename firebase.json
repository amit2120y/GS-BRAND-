{
  "hosting": {
    "public": "client",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/node_modules/**",
      ".env",
      ".env.*"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
      }
    ]
  },
  "firestore": {
    "rules": "server/firestore.rules"
  }
}
